# Anthropic Claude API 金鑰（取得後填入，並複製此檔為 .env.local）
# 申請網址：https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# 摘要模式：mock（預設，回傳假摘要）或 live（呼叫真實 Claude API）
# 取得金鑰前維持 mock，填好金鑰後改成 live
SUMMARIZE_MODE=mock

# 使用的 Claude 模型（live 模式生效）
# 預設用 claude-haiku-4-5（便宜、摘要足夠）；想要更高品質可改 claude-opus-4-8
ANTHROPIC_MODEL=claude-haiku-4-5

# YouTube Data API v3 金鑰（v2 搜尋功能使用）
# 申請：Google Cloud Console → 啟用 YouTube Data API v3 → 建立 API 金鑰
YOUTUBE_API_KEY=

# Supadata 金鑰（字幕來源；設定後優先使用，可繞過雲端 IP 封鎖、無字幕影片也能轉）
# 申請：https://supadata.ai （免費 100 次/月）；未設定則改用 youtube-transcript
SUPADATA_API_KEY=
